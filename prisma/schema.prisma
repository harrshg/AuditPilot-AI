generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ScanMode {
  QUICK
  DEEP
  SECURITY_FOCUSED
  PERFORMANCE_FOCUSED
  FULL_QA
}

enum ScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ScanEventLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum IssueSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum IssueCategory {
  SECURITY
  PERFORMANCE
  FRONTEND
  BACKEND_API
  NETWORK
  ACCESSIBILITY
  SERVER_CONFIG
  RELIABILITY
  TEST_COVERAGE
}

enum ArtifactType {
  SCREENSHOT
  VIDEO
  TRACE
  HAR
  LOG
  REPORT_JSON
  REPORT_MARKDOWN
  GENERATED_TEST_ARCHIVE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         UserRole @default(MEMBER)
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects Project[]
  scans    Scan[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  description String?
  baseUrl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  scanConfigs ScanConfig[]
  scans       Scan[]

  @@index([ownerId])
  @@map("projects")
}

model ScanConfig {
  id                       String   @id @default(cuid())
  projectId                String
  name                     String
  websiteUrl               String
  loginUrl                 String?
  issueDescription         String?
  scanMode                 ScanMode @default(QUICK)
  maxCrawlDepth            Int      @default(2)
  maxPages                 Int      @default(25)
  allowedDomains           Json
  excludedPaths            Json
  safeMode                 Boolean  @default(true)
  allowDestructiveActions  Boolean  @default(false)
  allowFormSubmission      Boolean  @default(false)
  allowFileUploadTesting   Boolean  @default(false)
  allowPaymentFlowTesting  Boolean  @default(false)
  authorizationTesterName  String
  authorizationOrgName     String?
  authorizationAcceptedAt  DateTime
  authorizationNotes       String?
  credentialsSecretRef     String?
  scheduleCron             String?
  scheduleEnabled          Boolean  @default(false)
  nextRunAt                DateTime?
  lastScheduledRunAt       DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scans   Scan[]

  @@index([projectId])
  @@index([scheduleEnabled, nextRunAt])
  @@map("scan_configs")
}

model Scan {
  id                    String     @id @default(cuid())
  projectId             String
  scanConfigId          String?
  requestedByUserId     String?
  status                ScanStatus @default(QUEUED)
  mode                  ScanMode
  targetUrl             String
  startedAt             DateTime?
  completedAt           DateTime?
  failureReason         String?
  overallHealthScore    Int?
  securityScore         Int?
  performanceScore      Int?
  frontendQualityScore  Int?
  backendApiScore       Int?
  accessibilityScore    Int?
  reliabilityScore      Int?
  testCoverageScore     Int?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scanConfig      ScanConfig?  @relation(fields: [scanConfigId], references: [id], onDelete: SetNull)
  requestedByUser User?        @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  events          ScanEvent[]
  pages           Page[]
  networkRequests NetworkRequest[]
  consoleLogs     ConsoleLog[]
  issues          Issue[]
  recommendations Recommendation[]
  generatedTests  GeneratedTest[]
  artifacts       Artifact[]

  @@index([projectId])
  @@index([scanConfigId])
  @@index([requestedByUserId])
  @@index([status])
  @@index([createdAt])
  @@map("scans")
}

model ScanEvent {
  id        String         @id @default(cuid())
  scanId    String
  level     ScanEventLevel @default(INFO)
  message   String
  metadata  Json?
  createdAt DateTime       @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([level])
  @@map("scan_events")
}

model Page {
  id             String   @id @default(cuid())
  scanId         String
  url            String
  title          String?
  statusCode     Int?
  loadTimeMs     Int?
  screenshotPath String?
  domSnapshotRef String?
  discoveredFrom String?
  visitedAt      DateTime @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([url])
  @@map("pages")
}

model NetworkRequest {
  id             String   @id @default(cuid())
  scanId         String
  pageUrl        String?
  requestUrl     String
  method         String
  statusCode     Int?
  resourceType   String?
  durationMs     Int?
  requestBytes   Int?
  responseBytes  Int?
  failed         Boolean  @default(false)
  failureText    String?
  requestHeaders Json?
  responseHeaders Json?
  createdAt      DateTime @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([statusCode])
  @@index([failed])
  @@index([requestUrl])
  @@map("network_requests")
}

model ConsoleLog {
  id        String   @id @default(cuid())
  scanId    String
  pageUrl   String?
  type      String
  text      String
  location  Json?
  createdAt DateTime @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([type])
  @@map("console_logs")
}

model Issue {
  id                  String        @id @default(cuid())
  scanId              String
  title               String
  description         String
  category            IssueCategory
  severity            IssueSeverity
  affectedUrl         String?
  affectedEndpoint    String?
  evidence            Json?
  reproductionSteps   Json?
  recommendationText  String?
  status              String        @default("OPEN")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  scan            Scan             @relation(fields: [scanId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]
  generatedTests  GeneratedTest[]

  @@index([scanId])
  @@index([category])
  @@index([severity])
  @@index([status])
  @@map("issues")
}

model Recommendation {
  id             String   @id @default(cuid())
  scanId         String
  issueId        String?
  title          String
  detail         String
  priority       Int      @default(3)
  estimatedEffort String?
  createdAt      DateTime @default(now())

  scan  Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  issue Issue? @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([scanId])
  @@index([issueId])
  @@index([priority])
  @@map("recommendations")
}

model GeneratedTest {
  id          String   @id @default(cuid())
  scanId      String
  issueId     String?
  fileName    String
  framework   String   @default("playwright")
  content     String
  metadata    Json?
  createdAt   DateTime @default(now())

  scan  Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
  issue Issue? @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([scanId])
  @@index([issueId])
  @@map("generated_tests")
}

model Artifact {
  id          String       @id @default(cuid())
  scanId      String
  type        ArtifactType
  fileName    String
  storagePath String
  mimeType    String?
  sizeBytes   Int?
  metadata    Json?
  createdAt   DateTime     @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([type])
  @@map("artifacts")
}
